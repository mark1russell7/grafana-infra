          "expr": "rate(lag_loaf_blocking_histogram_sum{service_name=~\"$service\"}[1m]) / rate(lag_loaf_blocking_histogram_count{service_name=~\"$service\"}[1m])",
          "legendFormat": "avg blocking"
        },
        {
          "expr": "histogram_quantile(0.95, rate(lag_loaf_blocking_histogram_bucket{service_name=~\"$service\"}[1m]))",
          "legendFormat": "p95 blocking"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "INP (Interaction to Next Paint)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "lag_inp_worst_gauge{service_name=~\"$service\"}",
          "legendFormat": "INP (worst)"
