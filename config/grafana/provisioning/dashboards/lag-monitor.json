  "schemaVersion": 39,
  "tags": ["lag", "performance", "otel"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "definition": "label_values(lag_continuous_histogram_count, service_name)",
        "includeAll": true,
        "name": "service",
        "query": "label_values(lag_continuous_histogram_count, service_name)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Lag Monitor",
  "uid": "lag-monitor",
  "version": 1
