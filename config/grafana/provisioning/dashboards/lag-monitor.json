{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Timer-Based Monitors",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Continuous Lag (avg, ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "rate(lag_continuous_histogram_sum{service_name=~\"$service\"}[1m]) / rate(lag_continuous_histogram_count{service_name=~\"$service\"}[1m])",
          "legendFormat": "avg"
        },
        {
          "expr": "histogram_quantile(0.95, rate(lag_continuous_histogram_bucket{service_name=~\"$service\"}[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(lag_continuous_histogram_bucket{service_name=~\"$service\"}[1m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Drift Lag (avg, ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "rate(lag_drift_histogram_sum{service_name=~\"$service\"}[1m]) / rate(lag_drift_histogram_count{service_name=~\"$service\"}[1m])",
          "legendFormat": "avg"
        },
        {
          "expr": "histogram_quantile(0.95, rate(lag_drift_histogram_bucket{service_name=~\"$service\"}[1m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Macrotask Lag (avg, ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "rate(lag_macrotask_histogram_sum{service_name=~\"$service\"}[1m]) / rate(lag_macrotask_histogram_count{service_name=~\"$service\"}[1m])",
          "legendFormat": "avg"
        },
        {
          "expr": "histogram_quantile(0.95, rate(lag_macrotask_histogram_bucket{service_name=~\"$service\"}[1m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Measurement Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "rate(lag_continuous_histogram_count{service_name=~\"$service\"}[1m])",
          "legendFormat": "continuous"
        },
        {
          "expr": "rate(lag_drift_histogram_count{service_name=~\"$service\"}[1m])",
          "legendFormat": "drift"
        },
        {
          "expr": "rate(lag_macrotask_histogram_count{service_name=~\"$service\"}[1m])",
          "legendFormat": "macrotask"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "title": "Max Lag Gauges",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "lag_continuous_max_gauge{service_name=~\"$service\"}",
          "legendFormat": "continuous max"
        },
        {
          "expr": "lag_drift_max_gauge{service_name=~\"$service\"}",
          "legendFormat": "drift max"
        },
        {
          "expr": "lag_macrotask_max_gauge{service_name=~\"$service\"}",
          "legendFormat": "macrotask max"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "title": "Performance Observers",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
