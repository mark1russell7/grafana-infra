        {
          "expr": "rate(lag_inp_histogram_sum{service_name=~\"$service\"}[1m]) / rate(lag_inp_histogram_count{service_name=~\"$service\"}[1m])",
          "legendFormat": "avg interaction"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "CLS (Cumulative Layout Shift)",
      "type": "gauge",
